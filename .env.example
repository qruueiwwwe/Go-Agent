# 服务器配置
SERVER_PORT=8080
SERVER_READ_TIMEOUT=30s
SERVER_WRITE_TIMEOUT=30s
SERVER_IDLE_TIMEOUT=60s

# Ollama 配置
OLLAMA_HOST=localhost:11434
OLLAMA_MODEL=qwen:7b
OLLAMA_TIMEOUT=120s

# 日志配置
LOG_LEVEL=info
LOG_PATH=./logs
LOG_MAX_SIZE=100
LOG_MAX_BACKUPS=30
LOG_MAX_AGE=7
LOG_COMPRESS=true

# 数据库配置（可选）
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_USER=root
DATABASE_PASSWORD=
DATABASE_DBNAME=agent
DATABASE_MAX_OPEN=10
DATABASE_MAX_IDLE=5

# Redis 配置（可选）
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=10

# 时区
TZ=Asia/Shanghai
